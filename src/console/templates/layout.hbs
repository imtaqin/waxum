<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{title}} — Waxum Console</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Zen+Maru+Gothic:wght@500;700;800&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/assets/console.css">
<link rel="icon" type="image/png" href="/assets/logo.png">
</head>
<body>
<svg width="0" height="0" style="position:absolute" aria-hidden="true">
  <defs>
    <symbol id="i-power" viewBox="0 0 16 16"><path fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" d="M8 1v7M4.5 3a6 6 0 1 0 7 0"/></symbol>
    <symbol id="i-plus" viewBox="0 0 16 16"><path fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" d="M8 3v10M3 8h10"/></symbol>
    <symbol id="i-x" viewBox="0 0 16 16"><path fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" d="M3.5 3.5l9 9M12.5 3.5l-9 9"/></symbol>
    <symbol id="i-arrow" viewBox="0 0 16 16"><path fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" d="M3 8h10m-4-4l4 4-4 4"/></symbol>
    <symbol id="i-trash" viewBox="0 0 16 16"><path fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" d="M3 4h10M6 4V2.5A.5.5 0 0 1 6.5 2h3a.5.5 0 0 1 .5.5V4m-5 0v9a1 1 0 0 0 1 1h5a1 1 0 0 0 1-1V4"/></symbol>
    <symbol id="i-qr" viewBox="0 0 16 16"><path fill="none" stroke="currentColor" stroke-width="1.3" d="M2 2h4v4H2zM10 2h4v4h-4zM2 10h4v4H2zM10 10v1M11 12v2M13 10h1M10 14h4"/></symbol>
    <symbol id="i-refresh" viewBox="0 0 16 16"><path fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" d="M3 8a5 5 0 0 1 8.5-3.5L14 7m0-4v4h-4M13 8a5 5 0 0 1-8.5 3.5L2 9m0 4V9h4"/></symbol>
    <symbol id="i-dot" viewBox="0 0 16 16"><circle cx="8" cy="8" r="3" fill="currentColor"/></symbol>
    <symbol id="i-book" viewBox="0 0 16 16"><path fill="none" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round" d="M3 3h5a2 2 0 0 1 2 2v8a2 2 0 0 0-2-2H3zM13 3H8a2 2 0 0 0-2 2v8a2 2 0 0 1 2-2h5z"/></symbol>
    <symbol id="i-signal" viewBox="0 0 16 16"><path fill="currentColor" d="M2 12h2v2H2zM6 9h2v5H6zM10 6h2v8h-2zM14 3h2v11h-2z" transform="translate(-1 0)"/></symbol>
  </defs>
</svg>

{{> body}}

</body>
</html>
