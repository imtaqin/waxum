# Database Configuration
# Supports: PostgreSQL, MySQL, SQLite
# Examples:
#   DATABASE_URL=postgres://user:password@localhost:5432/wagateway
#   DATABASE_URL=mysql://user:password@localhost:3306/wagateway
#   DATABASE_URL=sqlite://waxum.db
# DATABASE_URL=postgres://user:password@localhost:5432/wagateway

# Legacy PostgreSQL config (used as fallback if DATABASE_URL is not set)
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=
# POSTGRES_DB=wagateway

# JWT Configuration
# JWT_SECRET=change-me-in-production

# WhatsApp Session Storage
WHATSAPP_STORAGE_PATH=./whatsapp_sessions

# NATS JetStream (optional — omit NATS_URL to disable)
NATS_URL=nats://localhost:4222
NATS_EVENTS_STREAM=WA_EVENTS
NATS_SEND_STREAM=WA_SEND
NATS_EVENTS_MAX_AGE_DAYS=7
NATS_SEND_MAX_AGE_DAYS=1
# NATS_TOKEN=
# NATS_CREDS_FILE=

# Scheduled send dispatcher (optional)
# Poll interval in milliseconds for the background task that dispatches
# due scheduled messages (default 1000).
# SCHEDULER_POLL_MS=1000

# Blast (bulk-send) worker (optional)
# Poll interval in milliseconds for the background task that claims and
# drains blast jobs (default 1000).
# BLAST_POLL_MS=1000

# Logging
RUST_LOG=waxum=info,tower_http=info
